# ============================================================
# Java Code Analyzer - .gitignore
# ============================================================

# ----- Sensitive configuration (NEVER commit API keys!) -----
src/main/resources/config.properties
**/config.properties
.env
.env.*
!.env.example

# ----- Maven build output -----
target/
bin/
*.class
*.jar
*.war
*.ear

# ----- IDE files -----
.idea/
*.iml
*.iws
*.ipr
.vscode/settings.json
*.eclipse
.classpath
.project
.settings/

# ----- OS generated -----
.DS_Store
Thumbs.db
desktop.ini

# ----- Logs -----
*.log
logs/

# ----- Chrome driver cache -----
.wdm/

# ----- Backup -----
Analyze-backup/
